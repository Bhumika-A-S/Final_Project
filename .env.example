# TipTrack Payment Configuration
# Copy this to .env and fill in your actual credentials

# Payment: Razorpay (Default payment provider)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Payment: Stripe (Alternative payment provider)
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Advanced Sentiment Analysis (LLM-based Feedback Intelligence)
# Choose ONE provider: local (default), openai, or gemini

# Local BERT/RoBERTa (default, no API key needed, runs offline)
SENTIMENT_PROVIDER=local

# OpenAI (GPT-3.5/GPT-4 for advanced analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Free tier available)
GEMINI_API_KEY=AIza_xxxxxxxxxxxxx

# App Configuration
PAYMENT_PROVIDER=razorpay  # razorpay or stripe
APP_BASE_URL=http://localhost:8501
API_BASE_URL=http://localhost:8000
# QR signing secret for dynamic QR codes (keep private)
QR_SECRET=replace_with_a_random_secret
QR_EXPIRY_HOURS=24
